  # Update permutation
  out <- updatePermutation(distr, partitionSamples[i,], k=length(data)/2)
  distr <- out$distr
  nAcceptancesPermutation <- nAcceptancesPermutation + out$accepted
  # Update shrinkage
  distr <- updateShrinkage(distr, partitionSamples[i,], randomizeShrinkage=randomizeShrinkage)
