  }, 0), nSamples)
nAcceptancesPermutation <- nAcceptancesConcentration <- nAcceptancesDiscount <- 0L

doAlgorithm3 <- sample(c(TRUE,FALSE),1)
for ( i in 2:nSamples ) {
  # Update partition
  if ( doAlgorithm3 ) {
    partitionSamples[i,] <- nealAlgorithm3(partitionSamples[i-1,], distr,
                                           logIntegratedLikelihoodItem, mcmcTuning)$partition
  } else {
    out <- nealAlgorithm8(partitionSamples[i-1,], parametersSamples[[i-1]], distr,
