# Neal (2000) model and data
data <- c(-1.48, -1.40, -1.16, -1.08, -1.02, 0.14, 0.51, 0.53, 0.78)
sigma2 <- 0.1^2
mu0 <- 0
sigma02 <- 1

## For Neal Algorithm 3
logIntegratedLikelihoodItem <- function(i, subset) {
  posteriorVariance     <- 1 / ( 1/sigma02 + length(subset)/sigma2 )
  posteriorMean         <- posteriorVariance * ( mu0/sigma02 + sum(data[subset])/sigma2 )
  posteriorPredictiveSD <- sqrt(posteriorVariance + sigma2)
  dnorm(data[i], posteriorMean, posteriorPredictiveSD, log=TRUE)
}

## For Neal Algorithm 8
logLikelihoodOfItem <- function(i, parameter) {
  dnorm(data[i], mean=parameter, sd=sqrt(sigma2), log=TRUE)
}

sampleParameter <- function() {
  rnorm(1, mean=mu0, sd=sqrt(sigma02))
}

updateParameter <- function(parameter, subset) {
  posteriorVariance <- 1 / ( 1/sigma02 + length(subset)/sigma2 )
  posteriorMean     <- posteriorVariance * ( mu0/sigma02 + sum(data[subset])/sigma2 )
  rnorm(1, mean=posteriorMean, sd=sqrt(posteriorVariance))
}

# Prior partition distribution.  Many are supported.
whichDistr <- sample(c("up","jlp","crp","epa","lsp","cpp","sp"),1)
cat("Using selected distribution: ", whichDistr, "\n", sep="")
concentration <- 1.5
discount <- 0.2
anchor <- c(1,1,2,2,2,3,4,4,4)
permutation <- sample(length(anchor))
distr <- if ( whichDistr == "up" ) {
  UniformPartition(nItems=length(data))
} else if ( whichDistr == "jlp" ) {
  JensenLiuPartition(concentration=concentration, permutation=permutation)
} else if ( whichDistr == "crp" ) {
  CRPPartition(nItems=length(data), concentration=concentration, discount=discount)
} else if ( whichDistr == "epa" ) {
  subset <- c("Maine","Georgia","California","Minnesota","Oregon",
              "Utah","Wisconsin","Texas","Nevada")
  d <- as.matrix(dist(scale(USArrests[subset,])))
  temperature <- 1.0
  similarity <- exp( -temperature * d )
  EPAPartition(similarity, permutation, concentration, discount)
} else if ( whichDistr == "lsp" ) {
  randomizeShrinkage <- sample(c("fixed","common"),1)
  shrinkage <- 2
  LocationScalePartition(anchor, shrinkage=shrinkage,
                         concentration=concentration, permutation=permutation)
} else if ( whichDistr == "cpp" ) {
  randomizeShrinkage <- "fixed"
  shrinkage <- 2
  CenteredPartition(anchor=anchor, shrinkage=shrinkage,
                    baseline=CRPPartition(nItems=length(data),
                                          concentration=concentration, discount=discount))
} else if ( whichDistr == "sp" ) {
  randomizeShrinkage <- sample(c("fixed","common","cluster","idiosyncratic"),1)
  shrinkage <- if ( randomizeShrinkage == "common" ) c(0.2,0.2,0,0,0,0.2,0.2,0.2,0.2)
  else if ( randomizeShrinkage == "cluster" ) c(0.2,0.2,0,0,0,0.1,0.4,0.4,0.4)
  else if ( randomizeShrinkage == "idiosyncratic" ) c(0.2,0.2,0,0,0,0.1,0.4,0.4,0.4)
  else if ( randomizeShrinkage == "fixed" ) c(0.2,0.2,0,0,0,0.1,0.4,0.4,0.4)
  else stop("Unrecognized 'randomizeShrinkage'")
  ShrinkagePartition(anchor, shrinkage=shrinkage, permutation, grit=0.2,
                     baseline=CRPPartition(nItems=length(data),
                                           concentration=concentration, discount=discount))
} else stop("Unrecongized distribution")

