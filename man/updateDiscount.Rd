    getOr(distr$baseline$concentration,0)
  } else {
    getOr(distr$concentration,0)
  }
  # Update discount
  out <- updateDiscount(distr, partitionSamples[i,], rwsd=0.1)
  distr <- out$distr
  nAcceptancesDiscount <- nAcceptancesDiscount + out$accepted
  discountSamples[i] <- if ( inherits(distr,"ShrinkagePartition") ) {
    getOr(distr$baseline$discount,0)
  } else {
    getOr(distr$discount,0)
  }
